generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id             Int             @id @default(autoincrement())
  nome           String          @unique
  projetos       Projeto[]
  movimentacoes  Movimentacao[]
  agendaItens    Agenda[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ContaBancaria {
  id                   Int             @id @default(autoincrement())
  nome                 String
  banco                String
  saldoAtual           Decimal         @default(0) @map("saldo_atual") @db.Decimal(14, 2)
  movimentacoesOrigem  Movimentacao[]  @relation("ContaOrigem")
  movimentacoesDestino Movimentacao[]  @relation("ContaDestino")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([nome, banco])
  @@map("contas_bancarias")
}

model Projeto {
  id            Int            @id @default(autoincrement())
  nome          String
  empresaId     Int            @map("empresa_id")
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  movimentacoes Movimentacao[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([nome, empresaId])
  @@map("projetos")
}

model Movimentacao {
  id            Int                    @id @default(autoincrement())
  data          DateTime
  valor         Decimal                @db.Decimal(14, 2)
  tipo          MovimentacaoTipo
  categoria     MovimentacaoCategoria?
  tipoDespesa   TipoDespesa?           @map("tipo_despesa")
  canalOrigem   String?                @map("canal_origem")
  centroOperacao String?               @map("centro_operacao")
  referencia    String?
  status        MovimentacaoStatus
  subcategoria  GiraKidsSubcategoria?
  empresaId     Int                    @map("empresa_id")
  projetoId     Int?                   @map("projeto_id")
  contaOrigemId Int?                   @map("conta_origem_id")
  contaDestinoId Int?                  @map("conta_destino_id")
  empresa       Empresa                @relation(fields: [empresaId], references: [id])
  projeto       Projeto?               @relation(fields: [projetoId], references: [id])
  contaOrigem   ContaBancaria?         @relation("ContaOrigem", fields: [contaOrigemId], references: [id])
  contaDestino  ContaBancaria?         @relation("ContaDestino", fields: [contaDestinoId], references: [id])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([empresaId, status, tipo])
  @@index([data])
  @@map("movimentacoes")
}

model Fornecedor {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descricao   String?
  ativo       Boolean   @default(true)
  agendaItens Agenda[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("fornecedores")
}

model Agenda {
  id                    Int              @id @default(autoincrement())
  data                  DateTime
  titulo                String
  descricao             String?
  origem                String?
  origemTipo            AgendaOrigem?    @map("origem_tipo")
  tipoPagamento         AgendaTipoPagamento? @map("tipo_pagamento")
  valor                 Decimal          @db.Decimal(14, 2)
  prioridade            String
  status                AgendaStatus
  tipo                  AgendaTipo
  recurrenteAte         DateTime?        @map("recorrente_ate")
  fornecedorId          Int?             @map("fornecedor_id")
  fornecedor            Fornecedor?      @relation(fields: [fornecedorId], references: [id])
  origemExterna         Boolean          @default(false) @map("origem_externa")
  referenciaExternaId   String?          @map("referencia_externa_id")
  usuarioAprovadorId    Int?             @map("usuario_aprovador_id")
  dataAprovacao         DateTime?        @map("data_aprovacao")
  empresaId             Int              @map("empresa_id")
  empresa               Empresa          @relation(fields: [empresaId], references: [id])
  usuarioAprovador      Usuario?         @relation(fields: [usuarioAprovadorId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([data, status, origemExterna])
  @@index([referenciaExternaId])
  @@index([fornecedorId])
  @@map("agenda")
}

model Usuario {
  id                Int          @id @default(autoincrement())
  nome              String
  email             String       @unique
  senhaHash         String       @map("senha_hash")
  perfil            PerfilUsuario @default(FINANCEIRO)
  tema              TemaUsuario  @default(LIGHT)
  ativo             Boolean      @default(true)
  ultimoLoginAt     DateTime?    @map("ultimo_login_at")
  agendaAprovadas   Agenda[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("usuarios")
}

enum MovimentacaoTipo {
  ENTRADA
  SAIDA
  TRANSFERENCIA
}

enum MovimentacaoCategoria {
  PEDIDO
  COMISSAO
  RECOLHE_LOJAS
  BOLETO
  CHEQUE
  AJUSTE_SALDO
  FORNECEDOR
  CUSTO_FIXO
  CUSTO_VARIAVEL
  INVESTIMENTO
  PREJUIZO
}

enum MovimentacaoStatus {
  PREVISTO
  REALIZADO
}

enum TipoDespesa {
  DESPESAS_ADMINISTRATIVAS
  RETIRADA_SOCIOS
  FOLHA_PAGAMENTO
  DESPESAS_DIVERSAS
  GASOLINA
  MATERIAL_ESCRITORIO
  MATERIAL_ESTOQUE_EMBALAGENS
  CUSTOS_OPERACIONAIS
}

enum GiraKidsSubcategoria {
  TAKE_PARCERIA
  PELUCIA_PARCERIA
  OUTROS
}

enum AgendaStatus {
  ATRASADO
  PENDENTE_INTEGRACAO
  PREVISTO
  REALIZADO
}

enum AgendaTipo {
  PAGAR
  RECEBER
}

enum AgendaOrigem {
  DOACAO
  FORNECEDOR
  CF
  CV
  DIVERSOS
  FP
}

enum AgendaTipoPagamento {
  PIX
  TRANSFERENCIA
  CHEQUE
  BOLETO
}

enum PerfilUsuario {
  ADMIN
  FINANCEIRO
}

enum TemaUsuario {
  LIGHT
  DARK
}