generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id             Int             @id @default(autoincrement())
  nome           String          @unique
  projetos       Projeto[]
  movimentacoes  Movimentacao[]
  agendaItens    Agenda[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ContaBancaria {
  id                   Int             @id @default(autoincrement())
  nome                 String
  banco                String
  observacoes          String?
  saldoAtual           Decimal         @default(0) @map("saldo_atual") @db.Decimal(14, 2)
  movimentacoesOrigem  Movimentacao[]  @relation("ContaOrigem")
  movimentacoesDestino Movimentacao[]  @relation("ContaDestino")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([nome, banco])
  @@map("contas_bancarias")
}

model Projeto {
  id            Int            @id @default(autoincrement())
  nome          String
  empresaId     Int            @map("empresa_id")
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  movimentacoes Movimentacao[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([nome, empresaId])
  @@map("projetos")
}

model Movimentacao {
  id            Int                    @id @default(autoincrement())
  data          DateTime
  valor         Decimal                @db.Decimal(14, 2)
  tipo          MovimentacaoTipo
  categoria     MovimentacaoCategoria?
  tipoDespesa   TipoDespesa?           @map("tipo_despesa")
  canalOrigem   String?                @map("canal_origem")
  centroOperacao String?               @map("centro_operacao")
  referencia    String?
  status        MovimentacaoStatus
  subcategoria  GiraKidsSubcategoria?
  empresaId     Int                    @map("empresa_id")
  projetoId     Int?                   @map("projeto_id")
  saasClienteId Int?                   @map("saas_cliente_id")
  saasLancamentoTipo SaasLancamentoTipo? @map("saas_lancamento_tipo")
  contaOrigemId Int?                   @map("conta_origem_id")
  contaDestinoId Int?                  @map("conta_destino_id")
  empresa       Empresa                @relation(fields: [empresaId], references: [id])
  projeto       Projeto?               @relation(fields: [projetoId], references: [id])
  saasCliente   SaasCliente?           @relation(fields: [saasClienteId], references: [id])
  contaOrigem   ContaBancaria?         @relation("ContaOrigem", fields: [contaOrigemId], references: [id])
  contaDestino  ContaBancaria?         @relation("ContaDestino", fields: [contaDestinoId], references: [id])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([empresaId, status, tipo])
  @@index([data])
  @@index([saasClienteId, saasLancamentoTipo])
  @@map("movimentacoes")
}

model Fornecedor {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  descricao   String?
  ativo       Boolean   @default(true)
  agendaItens Agenda[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("fornecedores")
}

model Agenda {
  id                    Int              @id @default(autoincrement())
  data                  DateTime
  titulo                String
  descricao             String?
  origem                String?
  origemTipo            AgendaOrigem?    @map("origem_tipo")
  tipoPagamento         AgendaTipoPagamento? @map("tipo_pagamento")
  valor                 Decimal          @db.Decimal(14, 2)
  prioridade            String
  status                AgendaStatus
  tipo                  AgendaTipo
  recurrenteAte         DateTime?        @map("recorrente_ate")
  fornecedorId          Int?             @map("fornecedor_id")
  fornecedor            Fornecedor?      @relation(fields: [fornecedorId], references: [id])
  origemExterna         Boolean          @default(false) @map("origem_externa")
  referenciaExternaId   String?          @map("referencia_externa_id")
  usuarioAprovadorId    Int?             @map("usuario_aprovador_id")
  dataAprovacao         DateTime?        @map("data_aprovacao")
  empresaId             Int              @map("empresa_id")
  empresa               Empresa          @relation(fields: [empresaId], references: [id])
  usuarioAprovador      Usuario?         @relation(fields: [usuarioAprovadorId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([data, status, origemExterna])
  @@index([referenciaExternaId])
  @@index([fornecedorId])
  @@map("agenda")
}

model Usuario {
  id                Int          @id @default(autoincrement())
  nome              String
  email             String       @unique
  senhaHash         String       @map("senha_hash")
  perfil            PerfilUsuario @default(FINANCEIRO)
  tema              TemaUsuario  @default(LIGHT)
  ativo             Boolean      @default(true)
  ultimoLoginAt     DateTime?    @map("ultimo_login_at")
  agendaAprovadas   Agenda[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("usuarios")
}

model SaasCliente {
  id                     Int                 @id @default(autoincrement())
  nomeCliente            String              @map("nome_cliente")
  nomeSistema            String              @map("nome_sistema")
  logoParceiraUrl        String?             @map("logo_parceira_url")
  logoSelfMachineUrl     String?             @map("logo_selfmachine_url")
  vendedor               String
  numeroPc               String              @map("numero_pc")
  dataEmissao            DateTime            @map("data_emissao")
  tipoRemessa            TipoRemessa
  valorDesenvolvimento   Decimal?            @map("valor_desenvolvimento") @db.Decimal(14, 2)
  valorMensalidade       Decimal             @map("valor_mensalidade") @db.Decimal(14, 2)
  dataInicioMensalidade  DateTime            @map("data_inicio_mensalidade")
  condicoesPagamento     String?             @map("condicoes_pagamento")
  meioPagamento          String?             @map("meio_pagamento")
  chavePix               String?             @map("chave_pix")
  statusSistema          StatusSistemaSaas   @default(ATIVO) @map("status_sistema")
  statusMensalidade      StatusMensalidade   @default(AGUARDANDO_PAGAMENTO) @map("status_mensalidade")
  ultimaMensalidadePagaEm DateTime?          @map("ultima_mensalidade_paga_em")
  tipoPlano              TipoPlanoSaas       @map("tipo_plano")
  descricao              String?
  ultimoPedidoPagamentoAt DateTime?          @map("ultimo_pedido_pagamento_at")
  movimentacoes          Movimentacao[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([statusSistema])
  @@index([statusMensalidade])
  @@index([dataInicioMensalidade])
  @@map("saas_clientes")
}

enum MovimentacaoTipo {
  ENTRADA
  SAIDA
  TRANSFERENCIA
}

enum MovimentacaoCategoria {
  PEDIDO
  COMISSAO
  RECOLHE_LOJAS
  BOLETO
  CHEQUE
  AJUSTE_SALDO
  FORNECEDOR
  CUSTO_FIXO
  CUSTO_VARIAVEL
  INVESTIMENTO
  PREJUIZO
}

enum MovimentacaoStatus {
  PREVISTO
  REALIZADO
}

enum TipoDespesa {
  DESPESAS_ADMINISTRATIVAS
  RETIRADA_SOCIOS
  FOLHA_PAGAMENTO
  DESPESAS_DIVERSAS
  GASOLINA
  MATERIAL_ESCRITORIO
  MATERIAL_ESTOQUE_EMBALAGENS
  CUSTOS_OPERACIONAIS
}

enum GiraKidsSubcategoria {
  TAKE_PARCERIA
  PELUCIA_PARCERIA
  OUTROS
}

enum AgendaStatus {
  ATRASADO
  PENDENTE_INTEGRACAO
  PREVISTO
  REALIZADO
}

enum AgendaTipo {
  PAGAR
  RECEBER
}

enum AgendaOrigem {
  DOACAO
  FORNECEDOR
  CF
  CV
  DIVERSOS
  FP
}

enum AgendaTipoPagamento {
  PIX
  TRANSFERENCIA
  CHEQUE
  BOLETO
}

enum PerfilUsuario {
  ADMIN
  FINANCEIRO
}

enum TemaUsuario {
  LIGHT
  DARK
}

enum TipoRemessa {
  UNICA
  RECORRENTE
}

enum StatusSistemaSaas {
  ATIVO
  PAUSADO
  ATRASADO
  ENTREGUE
}

enum StatusMensalidade {
  AGUARDANDO_PAGAMENTO
  EM_ABERTO
  PAGO
  ATRASADO
  PAUSADO
}

enum TipoPlanoSaas {
  FULL
  SMALL
}

enum SaasLancamentoTipo {
  MENSALIDADE
  PAGAMENTO
}